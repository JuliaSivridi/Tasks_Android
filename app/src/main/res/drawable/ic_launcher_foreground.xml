<?xml version="1.0" encoding="utf-8"?>
<!--
  Foreground for the adaptive launcher icon (108×108dp).
  Design: checkbox (3,5 w10,h10) + checkmark (3,23→6,26→13,19) + 4 lines (x18-30)
  in a 30×30 coordinate space.

  Scale 1.8 → design fits ~49×38dp, centered in the 108dp canvas.
  translateX = 54 - 16.5×1.8 = 24.3
  translateY = 54 - 15.5×1.8 = 26.1
  Visible bounds: x[30..78], y[35..73] — well within the [18,90] safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="24.3"
        android:translateY="26.1"
        android:scaleX="1.8"
        android:scaleY="1.8">

        <!-- Checkbox: stroke-only rounded rect x=3,y=5 w=10,h=10 rx=1 -->
        <path
            android:pathData="M4,5 L12,5 A1,1 0 0 1 13,6 L13,14 A1,1 0 0 1 12,15 L4,15 A1,1 0 0 1 3,14 L3,6 A1,1 0 0 1 4,5 Z"
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.5" />

        <!-- Checkmark below the checkbox -->
        <path
            android:pathData="M3,23 L6,26 L13,19"
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />

        <!-- 4 horizontal lines -->
        <path
            android:pathData="M18,6 L30,6"
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M18,12 L30,12"
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M18,18 L30,18"
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M18,24 L30,24"
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.5"
            android:strokeLineCap="round" />

    </group>
</vector>
